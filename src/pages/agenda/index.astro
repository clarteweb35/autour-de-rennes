---
import { getCollection } from 'astro:content';
import { marches } from '../../data/marches.js';
import { saints } from '../../data/saints.js';
import { foodTrucks } from '../../data/foodtrucks.js';
import { visuelPour } from '../../data/visuels-categories.js';

const articles = await getCollection('articles', ({ data }) => !data.needs_human_review);

const aujourdhui = new Date();
aujourdhui.setHours(0, 0, 0, 0);

const articlesAVenir = articles.filter(article => {
  const dateFin = new Date(article.data.date_fin);
  return dateFin >= aujourdhui;
});

const articlesTries = articlesAVenir.sort((a, b) =>
  new Date(a.data.date_debut).getTime() - new Date(b.data.date_debut).getTime()
);

const categoriesUniques = [...new Set(articlesTries.map(a => a.data.categorie).filter(Boolean))].sort();

const evenementsALaUne = articlesTries.slice(0, 3);

function formaterJourMois(dateStr: string) {
  const date = new Date(dateStr);
  return {
    jour: date.toLocaleDateString('fr-FR', { day: 'numeric' }),
    mois: date.toLocaleDateString('fr-FR', { month: 'short' }).replace('.', '')
  };
}

function estEnCours(dateDebut: string, dateFin: string) {
  const aujourdhui = new Date();
  aujourdhui.setHours(0, 0, 0, 0);
  const debut = new Date(dateDebut);
  const fin = new Date(dateFin);
  return debut < aujourdhui && fin >= aujourdhui;
}

const maintenant = new Date();
const jourSemaineTexte = maintenant.toLocaleDateString('fr-FR', { weekday: 'long' });
const dateLongue = maintenant.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
const cleJourMois = `${String(maintenant.getMonth() + 1).padStart(2, '0')}-${String(maintenant.getDate()).padStart(2, '0')}`;
const saintDuJour = saints[cleJourMois] || null;

const marchesAujourdhui = marches.filter(m => m.jour === jourSemaineTexte || m.jour === 'tous les jours');
const foodTrucksAujourdhui = foodTrucks.filter(f => f.jour === jourSemaineTexte);
const foodTrucksVariables = foodTrucks.filter(f => f.jour === 'variable');

let prochainsFoodTrucks = [];
let prochainJourLabel = '';
if (foodTrucksAujourdhui.length === 0) {
  const ordreJours = ['dimanche', 'lundi', 'mardi', 'mercredi', 'jeudi', 'vendredi', 'samedi'];
  const indexAujourdhui = ordreJours.indexOf(jourSemaineTexte);
  const foodTrucksFixes = foodTrucks.filter(f => f.jour !== 'variable');

  let distanceMin = 8;
  for (const f of foodTrucksFixes) {
    const indexJour = ordreJours.indexOf(f.jour);
    const distance = (indexJour - indexAujourdhui + 7) % 7;
    if (distance > 0 && distance < distanceMin) distanceMin = distance;
  }
  prochainsFoodTrucks = foodTrucksFixes.filter(f => {
    const indexJour = ordreJours.indexOf(f.jour);
    const distance = (indexJour - indexAujourdhui + 7) % 7;
    return distance === distanceMin;
  });
  if (prochainsFoodTrucks.length > 0) {
    prochainJourLabel = prochainsFoodTrucks[0].jour.charAt(0).toUpperCase() + prochainsFoodTrucks[0].jour.slice(1);
  }
}
---
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Que faire aujourd'hui ? Agenda local</title>
  <meta name="description" content="Braderies, brocantes, événements culturels : l'agenda de Domagné, Châteaubourg, Vitré, Janzé, Châteaugiron et Rennes." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/autour-de-rennes/styles/global.css" />
</head>
<body>
  <header class="entete">
    <div class="entete-contenu">
      <a href="/autour-de-rennes/agenda/" class="logo-site">Autour de <em>Rennes</em></a>
      <nav class="nav-entete">
        <a href="/autour-de-rennes/annuaire/">Annuaire</a>
        <a href="/autour-de-rennes/pharmacies-garde/">Pharmacie de garde</a>
        <span class="sous-titre-site">Domagné · Châteaubourg · Vitré · Janzé · Châteaugiron</span>
      </nav>
      <a href="https://le-relais-de-chaumere.fr" target="_blank" rel="noopener" class="btn-gite">Mon gîte</a>
    </div>
  </header>

  <main class="conteneur">

    <!-- Bandeau fin : date/heure/fete + qualite de l'air -->
    <section class="bandeau-court">
      <div class="bandeau-court-date">
        <span class="bandeau-court-jour">{jourSemaineTexte} {dateLongue}</span>
        <span class="bandeau-court-heure" id="horloge">--:--</span>
        {saintDuJour && <span class="bandeau-court-saint">Bonne fête aux {saintDuJour} !</span>}
      </div>
      <div class="bandeau-court-air" id="bandeau-air-court">Qualité de l'air : chargement…</div>
    </section>

    <!-- Grille de 4 cartes resumees -->
    <div class="grille-infos">
      <div class="carte-info">
        <img class="carte-info-vignette" src="/autour-de-rennes/images/chalet-jardin.jpg" alt="Le Relais de Chaumeré" />
        <div class="carte-info-corps" id="bloc-meteo">
          <p class="carte-info-titre">Météo à Chaumeré</p>
          <p class="carte-info-contenu">Chargement…</p>
        </div>
      </div>

      <div class="carte-info">
        <img class="carte-info-vignette" src="/autour-de-rennes/images/marche.jpg" alt="Marché" />
        <div class="carte-info-corps">
          <p class="carte-info-titre">Marché{marchesAujourdhui.length > 1 ? 's' : ''} aujourd'hui</p>
          {marchesAujourdhui.length > 0 ? (
            <ul class="liste-courte">
              {marchesAujourdhui.slice(0, 2).map(m => (
                <li>{m.commune} <span class="liste-courte-detail">— {m.horaire}</span></li>
              ))}
            </ul>
          ) : (
            <p class="carte-info-contenu">Aucun marché aujourd'hui.</p>
          )}
          <a href="/autour-de-rennes/marches/" class="lien-plus">Tous les marchés →</a>
        </div>
      </div>

      <div class="carte-info">
        <img class="carte-info-vignette" src="/autour-de-rennes/images/foodtruck.jpg" alt="Food truck" />
        <div class="carte-info-corps">
          <p class="carte-info-titre">Food trucks aujourd'hui</p>
          {foodTrucksAujourdhui.length > 0 ? (
            <ul class="liste-courte">
              {foodTrucksAujourdhui.slice(0, 2).map(f => (
                <li>{f.nom} <span class="liste-courte-detail">— {f.specialite}</span></li>
              ))}
            </ul>
          ) : prochainsFoodTrucks.length > 0 ? (
            <p class="carte-info-contenu">Rien aujourd'hui. Prochain : <strong>{prochainJourLabel}</strong></p>
          ) : (
            <p class="carte-info-contenu">Aucun food truck recensé.</p>
          )}
          <a href="/autour-de-rennes/foodtrucks/" class="lien-plus">Tous les food trucks →</a>
        </div>
      </div>

      <div class="carte-info">
        <img class="carte-info-vignette" src="/autour-de-rennes/images/carburants.jpg" alt="Carburants" />
        <div class="carte-info-corps" id="bloc-carburants">
          <p class="carte-info-titre">Carburants à proximité</p>
          <p class="carte-info-contenu">Chargement…</p>
        </div>
      </div>
    </div>

    <div class="section-que-faire">
      <div class="que-faire-texte">
        <h1 class="titre-page">Que faire aujourd'hui ?</h1>
        <p class="chapo-page">Braderies, brocantes, marchés et rendez-vous culturels de Domagné, Châteaubourg, Vitré, Janzé, Châteaugiron et du bassin rennais, mis à jour chaque jour.</p>
      </div>
      <img class="que-faire-image" src="/autour-de-rennes/images/quoi-faire.jpg" alt="Autour de Domagné" />
    </div>

    {evenementsALaUne.length > 0 && (
      <div class="grille-alaune">
        {evenementsALaUne.map(article => {
          const d = article.data;
          const visuel = visuelPour(d.categorie);
          const dateAffichee = new Date(d.date_debut).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' });
          return (
            <a href={`/autour-de-rennes/agenda/${d.slug}`} class="carte-alaune">
              <div class="carte-alaune-image" style={`background: linear-gradient(135deg, ${visuel.c1}, ${visuel.c2});`}>
                {visuel.emoji}
              </div>
              <div class="carte-alaune-corps">
                <p class="carte-alaune-date">{dateAffichee}</p>
                <p class="carte-alaune-titre">{d.title}</p>
              </div>
            </a>
          );
        })}
      </div>
    )}

    {categoriesUniques.length > 0 && (
      <div class="filtres-categories" id="filtres-categories">
        <button class="filtre-chip filtre-chip-actif" data-categorie="Tout">Tout</button>
        {categoriesUniques.map(cat => (
          <button class="filtre-chip" data-categorie={cat}>{visuelPour(cat).emoji} {cat}</button>
        ))}
      </div>
    )}

    <div class="grille-evenements" id="grille-evenements">
      {articlesTries.map(article => {
        const d = article.data;
        const enCours = estEnCours(d.date_debut, d.date_fin);
        const { jour, mois } = formaterJourMois(enCours ? d.date_fin : d.date_debut);
        const visuel = visuelPour(d.categorie);
        return (
          <article class="carte-evenement" data-categorie={d.categorie || ''} style={`--couleur-carte: ${visuel.c2};`}>
            <div class="billet-date" style={`background: linear-gradient(135deg, ${visuel.c1}, ${visuel.c2});`}>
              <span class="billet-emoji">{visuel.emoji}</span>
              {enCours && <span class="billet-prefixe">Jusqu'au</span>}
              <span class="billet-jour">{jour}</span>
              <span class="billet-mois">{mois}</span>
            </div>
            <h2 class="carte-titre">
              <a href={`/autour-de-rennes/agenda/${d.slug}`}>{d.title}</a>
            </h2>
            <p class="carte-meta">📍 {d.lieu}, {d.ville}</p>
            <div class="carte-tags">
              {d.categorie && <span class="etiquette">{visuelPour(d.categorie).emoji} {d.categorie}</span>}
              {d.prix && <span class="etiquette prix">{d.prix}</span>}
            </div>
          </article>
        );
      })}
    </div>

    {articlesTries.length === 0 && <p>Aucun événement à venir pour le moment.</p>}
  </main>

  <footer class="pied-site">
    <p>Autour de Rennes — agenda mis à jour automatiquement à partir de sources officielles.</p>
    <nav class="pied-nav">
      <a href="/autour-de-rennes/a-propos/">À propos</a>
      <a href="/autour-de-rennes/sitemap.html">Plan du site</a>
      <a href="/autour-de-rennes/mentions-legales/">Mentions légales</a>
    </nav>
    <p>Site créé et édité par <a href="https://www.clarte-web.fr" target="_blank" rel="noopener" class="lien-credit">clarte-web.fr</a></p>
  </footer>

  <script>
    const boutonsFiltres = document.querySelectorAll('.filtre-chip');
    const cartesEvenements = document.querySelectorAll('.carte-evenement');

    boutonsFiltres.forEach(bouton => {
      bouton.addEventListener('click', () => {
        boutonsFiltres.forEach(b => b.classList.remove('filtre-chip-actif'));
        bouton.classList.add('filtre-chip-actif');

        const categorieChoisie = bouton.dataset.categorie;
        cartesEvenements.forEach(carte => {
          if (categorieChoisie === 'Tout' || carte.dataset.categorie === categorieChoisie) {
            carte.style.display = '';
          } else {
            carte.style.display = 'none';
          }
        });
      });
    });

    function majHorloge() {
      const el = document.getElementById('horloge');
      if (!el) return;
      const maintenant = new Date();
      el.textContent = maintenant.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    }
    majHorloge();
    setInterval(majHorloge, 1000 * 30);

    const codesMeteo = {
      0: '☀️ Ciel dégagé', 1: '🌤️ Peu nuageux', 2: '⛅ Partiellement nuageux', 3: '☁️ Couvert',
      45: '🌫️ Brouillard', 48: '🌫️ Brouillard givrant',
      51: '🌦️ Bruine légère', 53: '🌦️ Bruine', 55: '🌦️ Bruine forte',
      61: '🌧️ Pluie légère', 63: '🌧️ Pluie', 65: '🌧️ Pluie forte',
      71: '🌨️ Neige légère', 73: '🌨️ Neige', 75: '🌨️ Neige forte',
      80: '🌦️ Averses', 81: '🌦️ Averses fortes', 82: '⛈️ Averses violentes',
      95: '⛈️ Orage', 96: '⛈️ Orage avec grêle', 99: '⛈️ Orage violent'
    };

    async function chargerMeteo() {
      const bloc = document.getElementById('bloc-meteo');
      if (!bloc) return;
      try {
        const url = 'https://api.open-meteo.com/v1/forecast?latitude=48.04114&longitude=-1.423929&current=temperature_2m,weather_code&daily=temperature_2m_max,temperature_2m_min,weather_code&timezone=Europe%2FParis&forecast_days=4';
        const reponse = await fetch(url);
        const data = await reponse.json();

        const tempActuelle = Math.round(data.current.temperature_2m);
        const codeActuel = data.current.weather_code;
        const descActuelle = codesMeteo[codeActuel] || '';

        const previsions = data.daily.time.slice(1, 4).map((date, i) => {
          const jour = new Date(date).toLocaleDateString('fr-FR', { weekday: 'short' }).replace('.', '');
          const max = Math.round(data.daily.temperature_2m_max[i + 1]);
          const min = Math.round(data.daily.temperature_2m_min[i + 1]);
          const code = data.daily.weather_code[i + 1];
          const emoji = (codesMeteo[code] || '').split(' ')[0];
          return `<div class="previsions-jour"><span>${jour}</span><span>${emoji}</span><span>${max}°/${min}°</span></div>`;
        }).join('');

        bloc.innerHTML = `
          <p class="carte-info-titre">Météo à Chaumeré</p>
          <p class="carte-info-forte">${descActuelle} — ${tempActuelle}°C</p>
          <div class="previsions-semaine">${previsions}</div>
        `;
      } catch (e) {
        bloc.innerHTML = '<p class="carte-info-titre">Météo à Chaumeré</p><p class="carte-info-contenu">Indisponible pour le moment.</p>';
      }
    }
    chargerMeteo();

    async function chargerCarburants() {
      const bloc = document.getElementById('bloc-carburants');
      if (!bloc) return;
      try {
        const url = "https://data.economie.gouv.fr/api/explore/v2.1/catalog/datasets/prix-des-carburants-en-france-flux-instantane-v2/records?where=distance(geom,%20geom%27POINT(-1.423929%2048.04114)%27,%2020km)&limit=40";
        const reponse = await fetch(url);
        const data = await reponse.json();

        const stationsGazole = data.results
          .filter(s => s.gazole_prix)
          .sort((a, b) => a.gazole_prix - b.gazole_prix)
          .slice(0, 2);

        if (stationsGazole.length === 0) {
          bloc.innerHTML = '<p class="carte-info-titre">Carburants</p><p class="carte-info-contenu">Aucune donnée disponible.</p>';
          return;
        }

        const lignes = stationsGazole.map(s => `
          <li>${s.ville} <span class="liste-courte-detail">— ${s.gazole_prix.toFixed(3)} €</span></li>
        `).join('');

        bloc.innerHTML = `
          <p class="carte-info-titre">Gazole le moins cher</p>
          <ul class="liste-courte">${lignes}</ul>
          <div class="liens-carte">
            <a href="/autour-de-rennes/carburants/" class="lien-carte">Voir tous les carburants →</a>
            <a href="/autour-de-rennes/bornes-recharge/" class="lien-carte">Bornes de recharge électrique →</a>
          </div>
        `;
      } catch (e) {
        bloc.innerHTML = '<p class="carte-info-titre">Carburants</p><p class="carte-info-contenu">Indisponible pour le moment.</p>';
      }
    }
    chargerCarburants();

    function categorieAQI(valeur) {
      if (valeur <= 20) return { label: 'Bon', classe: 'aqi-bon' };
      if (valeur <= 40) return { label: 'Moyen', classe: 'aqi-moyen' };
      if (valeur <= 60) return { label: 'Dégradé', classe: 'aqi-degrade' };
      if (valeur <= 80) return { label: 'Mauvais', classe: 'aqi-mauvais' };
      return { label: 'Très mauvais', classe: 'aqi-tres-mauvais' };
    }

    async function chargerAir() {
      const bloc = document.getElementById('bandeau-air-court');
      if (!bloc) return;
      try {
        const url = 'https://air-quality-api.open-meteo.com/v1/air-quality?latitude=48.04114&longitude=-1.423929&current=european_aqi&hourly=birch_pollen,grass_pollen,alder_pollen,ragweed_pollen,mugwort_pollen,olive_pollen&timezone=Europe%2FParis&forecast_days=1';
        const reponse = await fetch(url);
        const data = await reponse.json();

        const aqi = Math.round(data.current.european_aqi);
        const cat = categorieAQI(aqi);

        const heureActuelle = new Date().getHours();
        const pollens = [
          { nom: 'Bouleau', valeur: data.hourly.birch_pollen[heureActuelle] },
          { nom: 'Graminées', valeur: data.hourly.grass_pollen[heureActuelle] },
          { nom: 'Aulne', valeur: data.hourly.alder_pollen[heureActuelle] },
          { nom: 'Ambroisie', valeur: data.hourly.ragweed_pollen[heureActuelle] },
          { nom: 'Armoise', valeur: data.hourly.mugwort_pollen[heureActuelle] },
          { nom: 'Olivier', valeur: data.hourly.olive_pollen[heureActuelle] }
        ].filter(p => p.valeur !== null && p.valeur > 5);

        const pollensTexte = pollens.length > 0 ? ` · Pollens : ${pollens.map(p => p.nom).join(', ')}` : '';

        bloc.innerHTML = `Qualité de l'air : <strong class="${cat.classe}">${cat.label}</strong> (indice ${aqi})${pollensTexte} — <a href="/autour-de-rennes/qualite-air/" class="bandeau-court-lien">Comparer en Bretagne →</a>`;
      } catch (e) {
        bloc.innerHTML = "Qualité de l'air : indisponible pour le moment.";
      }
    }
    chargerAir();
  </script>
</body>
</html>
