---
import { bornesRecharge } from '../../data/bornes-recharge.js';
---
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Bornes de recharge électrique près de Domagné | Autour de Rennes</title>
  <meta name="description" content="Trouvez une borne de recharge pour véhicule électrique près de Domagné, Châteaubourg, Châteaugiron et Servon-sur-Vilaine." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/autour-de-rennes/styles/global.css" />
</head>
<body>
  <header class="entete">
    <div class="entete-contenu">
      <a href="/autour-de-rennes/agenda/" class="logo-site">Autour de <em>Rennes</em></a>
      <nav class="nav-entete">
        <a href="/autour-de-rennes/annuaire/">Annuaire</a>
        <a href="/autour-de-rennes/pharmacies-garde/">Pharmacie de garde</a>
        <span class="sous-titre-site">L'agenda des sorties locales</span>
      </nav>
    </div>
  </header>

  <main class="conteneur">
    <a href="/autour-de-rennes/agenda/" class="fil-retour">← Retour à l'agenda</a>
    <h1 class="titre-page">Bornes de recharge électrique</h1>
    <p class="chapo-page">Toutes les bornes recensées autour de Domagné, triées par distance.</p>
    <p class="note-precision"><strong>AC</strong> = charge normale (recharge en quelques heures, connecteur Type 2). <strong>DC</strong> = charge rapide (recharge en 20-40 minutes, connecteur CCS Combo 2, tarif plus élevé).</p>

    <table class="table-carburants">
      <thead>
        <tr>
          <th>Commune</th>
          <th>Distance</th>
          <th>Opérateur</th>
          <th>Connecteurs</th>
          <th>Puissance</th>
          <th>Tarif indicatif</th>
        </tr>
      </thead>
      <tbody>
        {bornesRecharge.map(b => (
          <tr>
            <td>{b.commune}<br /><span class="station-adresse">{b.adresse}</span></td>
            <td>{b.distance}</td>
            <td>{b.nom}<br /><span class="station-adresse">{b.carte}</span></td>
            <td>{b.connecteurs}</td>
            <td>{b.puissance}</td>
            <td>{b.tarif}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <p class="note-precision">Tarifs et disponibilités indicatifs, susceptibles d'évoluer selon les opérateurs — vérifiez sur l'application dédiée avant de vous déplacer.</p>
  </main>

  <footer class="pied-site">
    <p>Autour de Rennes — données bornes de recharge mises à jour manuellement.</p>
  </footer>
</body>
</html>
